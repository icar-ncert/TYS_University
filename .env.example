# Database (SQLite for demo, PostgreSQL for production)
# For SQLite (demo):
DATABASE_URL="file:./db/custom.db"

# For PostgreSQL (production) - use one of:
# Local: postgresql://user:password@localhost:5432/tys_university
# Neon:  postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/tys?sslmode=require
# Supabase: postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres
# DATABASE_URL="postgresql://user:password@localhost:5432/tys_university"

# Auth
NEXTAUTH_SECRET="change-this-to-a-random-32-char-string"
NEXTAUTH_URL="http://localhost:3000"

# App
NODE_ENV="development"
PORT=3000

# Storage (optional - defaults to local)
# S3_ENDPOINT="https://xxx.r2.cloudflarestorage.com"
# S3_BUCKET="tys-university"
# S3_ACCESS_KEY="your-access-key"
# S3_SECRET_KEY="your-secret-key"

# Redis (optional - defaults to in-memory)
# REDIS_URL="redis://localhost:6379"

# Email (optional)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
